{
  "name": "@nestjs-stitcher/gateway",
  "version": "0.1.0",
  "description": "Schema stitching gateway module for NestJS GraphQL",
  "license": "MIT",
  "author": "Bridges Wood",
  "keywords": [
    "nestjs",
    "graphql",
    "schema-stitching",
    "federation",
    "gateway"
  ],
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bridges-wood/nestjs-stitcher.git",
    "directory": "packages/gateway"
  },
  "bugs": {
    "url": "https://github.com/bridges-wood/nestjs-stitcher/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@nestjs-stitcher/common": "0.1.0",
    "@nestjs-stitcher/auth": "0.1.0",
    "@graphql-tools/delegate": "^10.0.0",
    "@graphql-tools/stitch": "^9.0.0",
    "@graphql-tools/stitching-directives": "^3.1.0",
    "@graphql-tools/utils": "^10.0.0",
    "@graphql-tools/wrap": "^10.0.0",
    "exponential-backoff": "^3.1.0",
    "graphql-sse": "^2.0.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/graphql": "^13.0.0",
    "@nestjs/schedule": "^5.0.0",
    "graphql": "^16.9.0",
    "rxjs": "^7.8.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/config": {
      "optional": true
    },
    "@nestjs/schedule": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9"
  }
}
