{
  "name": "common",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/common/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "cd packages/common && swc src -d dist --strip-leading-paths --config-file ../../.swcrc --ignore '**/*.spec.ts'",
          "tsc -p packages/common/tsconfig.lib.json --outDir packages/common/dist --tsBuildInfoFile packages/common/dist/tsconfig.lib.tsbuildinfo --emitDeclarationOnly --declaration"
        ],
        "parallel": false,
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --project common",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
