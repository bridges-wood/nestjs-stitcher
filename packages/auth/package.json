{
  "name": "@nestjs-stitcher/auth",
  "version": "0.1.0",
  "description": "JWT authentication module with JWKS support for @nestjs-stitcher",
  "license": "MIT",
  "author": "Bridges Wood",
  "keywords": [
    "nestjs",
    "graphql",
    "schema-stitching",
    "federation",
    "auth",
    "jwt",
    "jwks"
  ],
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bridges-wood/nestjs-stitcher.git",
    "directory": "packages/auth"
  },
  "bugs": {
    "url": "https://github.com/bridges-wood/nestjs-stitcher/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@nestjs-stitcher/common": "0.1.0",
    "jose": "^6.0.0",
    "jwks-rsa": "^3.1.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/graphql": "^13.0.0",
    "graphql": "^16.9.0",
    "rxjs": "^7.8.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/config": {
      "optional": true
    }
  }
}
