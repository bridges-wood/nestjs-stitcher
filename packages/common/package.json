{
  "name": "@nestjs-stitcher/common",
  "version": "0.0.1",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bridges-wood/nestjs-stitcher.git",
    "directory": "packages/common"
  },
  "exports": {
    ".": {
      "@nestjs-stitcher/source": {
        "default": "./src/index.ts"
      },
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "json-stable-stringify": "^1.1.1"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "graphql": "^16.9.0"
  },
  "devDependencies": {
    "@types/json-stable-stringify": "^1.0.36"
  }
}
