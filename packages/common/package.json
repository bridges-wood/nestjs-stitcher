{
  "name": "@nestjs-stitcher/common",
  "version": "0.1.0",
  "description": "Shared types, HMAC utilities, and error classes for @nestjs-stitcher",
  "license": "MIT",
  "author": "Bridges Wood",
  "keywords": [
    "nestjs",
    "graphql",
    "schema-stitching",
    "federation",
    "common",
    "utilities",
    "hmac"
  ],
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bridges-wood/nestjs-stitcher.git",
    "directory": "packages/common"
  },
  "bugs": {
    "url": "https://github.com/bridges-wood/nestjs-stitcher/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "json-stable-stringify": "^1.1.1"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "graphql": "^16.9.0"
  },
  "devDependencies": {
    "@types/json-stable-stringify": "^1.0.36"
  }
}
